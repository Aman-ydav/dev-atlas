MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app-name>"

PORT=8000
NODE_ENV=development

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
# Comma-separated list of origins allowed to call this API with credentials.
# Dev: the Vite dev server. Prod: your deployed frontend's real origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match a redirect URI registered on this OAuth client in
# Google Cloud Console. Google allows multiple registered URIs on one
# client, so the same GOOGLE_CLIENT_ID/SECRET can be reused across
# environments — only this callback URL differs.
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback

# ─────────────────────────────────────────
# GITHUB OAUTH
# ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GitHub OAuth Apps (classic) only support ONE callback URL per app — unlike
# Google, you need a separate GitHub OAuth App per environment (dev vs prod),
# each with its own client ID/secret, if you want both to keep working.
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback

# ─────────────────────────────────────────
# ROLES
# ─────────────────────────────────────────
# Auto-promoted to super_admin on first login with this email.
SUPER_ADMIN_EMAIL=you@example.com

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=10d

# ─────────────────────────────────────────
# CLOUDINARY
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─────────────────────────────────────────
# WEB PUSH (VAPID) — reserved, not wired to any route yet
# ─────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────
# Used for OAuth-success/failure redirects. FRONTEND_URL is read when
# NODE_ENV != production, FRONTEND_URL_PROD when it is (constants.js).
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_PROD=
